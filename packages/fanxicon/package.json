{
  "name": "fanxicon",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./metadata": {
      "types": "./dist/metadata/icons.d.ts",
      "import": "./dist/metadata/icons.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync": "node scripts/sync-lucide-icons.mjs",
    "optimize": "node scripts/optimize-icons.mjs",
    "generate": "node scripts/generate-icons.mjs",
    "build": "pnpm run generate && node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json && node scripts/postbuild.mjs",
    "test": "pnpm run build && node --test tests/*.test.mjs",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0"
  }
}
