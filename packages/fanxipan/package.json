{
  "name": "fanxipan",
  "version": "1.0.7",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/duongonix/fanxipan"
  },
  "homepage": "https://github.com/duongonix/fanxipan#readme",
  "bugs": {
    "url": "https://github.com/duongonix/fanxipan/issues"
  },
  "dependencies": {
    "@fanxipan/runtime": "workspace:*",
    "@fanxipan/compiler": "workspace:*",
    "@fanxipan/router": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./reactivity": {
      "types": "./dist/reactivity.d.ts",
      "import": "./dist/reactivity.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./transitions": {
      "types": "./dist/transitions.d.ts",
      "import": "./dist/transitions.js"
    },
    "./package.json": "./package.json"
  }
}
