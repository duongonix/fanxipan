function App() {
  let n = $state(5)

  return (
    <main>
      {#snippet countdown(value)}
        {#if value > 0}
          <span>{value} </span>
          {@render countdown(value - 1)}
        {:else}
          <span>done</span>
        {/if}
      {/snippet}

      {@render countdown(n)}
    </main>
  )
}

export default App
